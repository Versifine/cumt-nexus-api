# ==========================================
# CUMT-Nexus 环境配置示例文件 (.env.example)
# ==========================================
# 【注意】此文件仅用于提供配置项的参考。
# 实际部署或本地开发时，请复制此文件并重命名为 .env

# ----- 服务基础配置 -----
APP_PORT=8080
APP_MODE=debug           # debug, release, test

# ----- 数据库配置 (MySQL) -----
DB_HOST=127.0.0.1        # 如果在 Docker 网络内，可能是 mysql
DB_PORT=3306
DB_USER=nexus_user
DB_PASSWORD=nexuspassword
DB_NAME=cumt_nexus_db
DB_ROOT_PASSWORD=rootpassword # 仅用于 Docker 容器初始化

# ----- 缓存配置 (Redis) -----
REDIS_HOST=127.0.0.1     # 如果在 Docker 网络内，可能是 redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# ----- 安全与认证 -----
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRE_HOURS=24